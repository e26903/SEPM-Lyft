{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health.ts"
    },
    {
      "source": "/api/ping",
      "destination": "/api/health.ts"
    },
    {
      "source": "/api/smartsheet-api-proxy",
      "destination": "/api/smartsheet.ts"
    },
    {
      "source": "/api/proxy-site-data",
      "destination": "/api/csv-proxy.ts"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
