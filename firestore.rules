rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null && 
             request.auth.token != null && 
             'email' in request.auth.token && 
             request.auth.token.email != null;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() in [
          'crcjehaas@gmail.com', 
          'charles_haas@outlook.com', 
          'ruth_haas@outlook.com', 
          'ruth.haas@sepmfix.com', 
          'andy.phipps@sepmfix.com'
        ] ||
        request.auth.token.email.lower().endsWith('@sepmfix.com')
      );
    }

    function isAuthorized() {
      return isSignedIn() && (
        isHardcodedAdmin() ||
        exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email.lower()))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    // Inspection Rules
    match /inspections/{inspectionId} {
      function isValidInspection(data) {
        return data.keys().hasAll(['id', 'status', 'createdAt', 'workOrderNo', 'storeNo', 'technicianName', 'userId'])
          && data.id is string && data.id.size() <= 128
          && data.status in ['draft', 'submitted']
          && data.workOrderNo is string && data.workOrderNo.size() <= 100
          && data.storeNo is string && data.storeNo.size() <= 50
          && data.technicianName is string && data.technicianName.size() <= 200
          && data.userId == request.auth.uid;
      }

      // Allow only authorized personnel to list and get reports
      allow list: if isHardcodedAdmin() || (isAuthorized() && resource.data.userId == request.auth.uid);
      allow get: if isHardcodedAdmin() || (isAuthorized() && existingData().userId == request.auth.uid);

      allow create: if isAuthorized() 
        && isValidId(inspectionId) 
        && isValidInspection(incomingData())
        && incomingData().id == inspectionId;

      allow update: if isAuthorized()
        && (existingData().userId == request.auth.uid || isHardcodedAdmin())
        && isValidInspection(incomingData())
        // Prevent editing submitted reports (terminal state)
        && (existingData().status != 'submitted' || incomingData().status == 'submitted' || isHardcodedAdmin())
        && incomingData().userId == existingData().userId
        && incomingData().id == existingData().id;

      allow delete: if isHardcodedAdmin() && (existingData().userId == request.auth.uid || request.auth.token.email.lower() == 'crcjehaas@gmail.com');
    }

    // Settings Rules
    match /settings/{settingId} {
      allow read: if isAuthorized();
      allow write: if isAuthorized();
    }

    // User Management Rules
    match /authorized_users/{email} {
      allow read: if isSignedIn();
      allow write: if isAuthorized() && request.auth.token.email.lower() == 'crcjehaas@gmail.com';
    }
  }
}
